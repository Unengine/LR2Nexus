<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LR2Nexus.ViewModels"
             xmlns:i18n="clr-namespace:LR2Nexus.I18n"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="620"
             x:Class="LR2Nexus.Views.Jukebox"
             x:DataType="vm:JukeboxViewModel"
             Background="Transparent">
    <DockPanel Margin="16,9,16,9" LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,9">
            <Grid ColumnDefinitions="*, 120, 120" Height="35" ColumnSpacing="5">
                <TextBlock Grid.Column="0" Text="{i18n:Translate BMSDirectores}" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Classes="ActionButton"
                        Content="{i18n:Translate Add}"
                        Click="OnAddPathClick"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"/>
                <Button Grid.Column="2"
                        Classes="ActionButton"
                        Content="{i18n:Translate Delete}"
                        Click="OnDeletePathClick"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"/>
            </Grid>
            <Border BorderBrush="LightGray" BorderThickness="0,0,0,1"/>
        </StackPanel>
        <Grid>
            <Path Data="{StaticResource AddFolderIcon}" 
                  Name="AddFolderIcon"
                  Width="300" Height="300"
                  Fill="Black" 
                  Stretch="Uniform" 
                  Opacity="0" />
            <ListBox ItemsSource="{Binding AvailablePathes}"
                     Name="PathListBox"
                     DragDrop.AllowDrop="True"
                     DragDrop.Drop="OnItemDropped"
                     DragDrop.DragOver="OnDragOver"
                     DragDrop.DragLeave="OnDragLeave"
                     Background="#10000000"
                     CornerRadius="4"
                     Padding="9,6">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0, 0"/>
                        <Setter Property="MinHeight" Value="20"/>
                    </Style>
                </ListBox.Styles>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="📁" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </DockPanel>
</UserControl>
