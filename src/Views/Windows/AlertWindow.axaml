<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        x:Class="LR2Nexus.View.AlertWindow"
        xmlns:vm="clr-namespace:LR2Nexus.ViewModel"
        Title="InputWindow"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SizeToContent="Height"
        x:DataType="vm:AlertWindowViewModel"
        d:DesignWidth="384"
        d:DesignHeight="216">
    <Viewbox Stretch="Uniform">
        <DockPanel Margin="20">
            <Button DockPanel.Dock="Bottom"
                    Name="ConfirmButton"
                    Classes="ActionButton"
                    Content="Confirm"
                    Click="OnConfirmClick"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0" />
            <ContentControl Name="MessageContainer" VerticalAlignment="Top" />
        </DockPanel>
    </Viewbox>
</Window>