<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        x:Class="LR2Nexus.View.LoadingWindow"
        xmlns:vm="clr-namespace:LR2Nexus.ViewModel"
        Title="InputWindow"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        SizeToContent="Height"
        x:DataType="vm:LoadingWindowViewModel"
        Background="#11000000"

        d:DesignWidth="1280"
        d:DesignHeight="720">
    	<Viewbox Stretch="Uniform">
            <ContentControl Name="MessageContainer" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Viewbox>
</Window>